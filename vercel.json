{
  "buildCommand": "cd frontend && npm run build && cd .. && cp backend/requirements-prod.txt .",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "backend/app.py": {
      "memory": 1024,
      "maxDuration": 30,
      "runtime": "python3.12"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/app.py"
    },
    {
      "source": "/health",
      "destination": "/backend/app.py"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/app.py"
    },
    {
      "src": "/health",
      "dest": "/backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
