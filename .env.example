# =============================================================
# LaunchSim Configuration
# =============================================================
# Cloud-native deployment layout.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== LLM Configuration (OpenAI-compatible format) =====
# Get a free API key at console.groq.com
LLM_API_KEY=your_groq_api_key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile

# ===== Neo4j Configuration =====
# Get a free cloud database at console.neo4j.io
NEO4J_URI=neo4j+s://your-cloud-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ===== Embedding Configuration =====
# Get a free Jina AI API key (or switch to OpenAI)
EMBEDDING_API_KEY=your_jina_api_key
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_BASE_URL=https://api.jina.ai/v1

# ===== OASIS / CAMEL-AI Configuration =====
OPENAI_API_KEY=your_groq_api_key
OPENAI_API_BASE_URL=https://api.groq.com/openai/v1
